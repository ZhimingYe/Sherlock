  "compilerOptions": {
    "noEmit": true,
    "rootDir": "src",
    "outDir": "dist",
    "module": "es2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["vscode", "node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/frontend"]
}
